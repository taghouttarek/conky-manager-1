#!/bin/bash
set -e

INSTALL_DIR="/opt/conky-manager"
LOCAL_DIR="/root/.local/share/conky-manager"
BIN_DIR="/usr/local/bin"
ICON_DIR="/usr/share/icons"
DESKTOP_DIR="/usr/share/applications"
REPO_URL="https://github.com/taghouti-org/conky-manager.git"
CLONE_DIR="/tmp/conky-manager-build"

echo "=== Conky Manager Installer ==="

# Clone repo to get all files
echo "Downloading Conky Manager..."
rm -rf "$CLONE_DIR"
git clone "$REPO_URL" "$CLONE_DIR"

# Install files to /opt
echo "Installing to $INSTALL_DIR..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
cp -r "$CLONE_DIR"/* "$INSTALL_DIR/"
chmod +x "$INSTALL_DIR/install.sh" 2>/dev/null || true
chmod +x "$INSTALL_DIR/conky_manager.py" 2>/dev/null || true

# Install Python dependencies
echo "Installing Python dependencies..."
pip3 install customtkinter --break-system-packages 2>/dev/null || \
pip3 install customtkinter 2>/dev/null || \
echo "Warning: Could not install customtkinter. Run: pip3 install customtkinter"

# Install themes to ~/.config/conky for all users
for user_dir in /home/*; do
    if [ -d "$user_dir/.config" ]; then
        user=$(basename "$user_dir")
        echo "Installing themes for user: $user"
        mkdir -p "$user_dir/.config/conky"
        for theme_dir in "$INSTALL_DIR/themes/"*-conky-manager; do
            if [ -d "$theme_dir" ]; then
                theme_name=$(basename "$theme_dir")
                rm -rf "$user_dir/.config/conky/$theme_name"
                cp -r "$theme_dir" "$user_dir/.config/conky/$theme_name"
            fi
        done
        # Install manager files for user
        mkdir -p "$user_dir/.local/share/conky-manager"
        cp "$INSTALL_DIR/conky_manager.py" "$user_dir/.local/share/conky-manager/"
        cp "$INSTALL_DIR/layout_editor.py" "$user_dir/.local/share/conky-manager/"
        chown -R "$user:$user" "$user_dir/.local/share/conky-manager" 2>/dev/null || true
        chown -R "$user:$user" "$user_dir/.config/conky" 2>/dev/null || true
    fi
done

# Create CLI wrapper
cat > "$BIN_DIR/conky-manager" << 'WRAPPER'
#!/bin/bash
LOCAL_APP="$HOME/.local/share/conky-manager/conky_manager.py"
if [ -f "$LOCAL_APP" ]; then
    exec python3 "$LOCAL_APP" "$@"
else
    exec python3 "/opt/conky-manager/conky_manager.py" "$@"
fi
WRAPPER
chmod +x "$BIN_DIR/conky-manager"

# Create desktop entry
mkdir -p "$DESKTOP_DIR"
cat > "$DESKTOP_DIR/conky-manager.desktop" << EOF
[Desktop Entry]
Name=Conky Manager
Comment=Manage and configure Conky themes
Exec=$BIN_DIR/conky-manager
Icon=$ICON_DIR/conky-manager.png
Terminal=false
Type=Application
Categories=Utility;System;
Keywords=conky;monitor;system;widget;
EOF

# Install icon
mkdir -p "$ICON_DIR"
if [ -f "$INSTALL_DIR/icon.png" ]; then
    cp "$INSTALL_DIR/icon.png" "$ICON_DIR/conky-manager.png"
fi

# Update desktop database
if command -v update-desktop-database &> /dev/null; then
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
fi

# Cleanup
rm -rf "$CLONE_DIR"

echo ""
echo "=== Installation Complete ==="
echo "Run: conky-manager"
echo "Or find 'Conky Manager' in your application menu"
